<% layout("/layouts/boilerplate") -%>
<%= success %>
<!-- <h3>All Listings</h3> -->
<!-- <form method="GET" action="/listings/new">
    <button>CREATE NEW Listings</button>
</form> -->
<style>
    #filters-container {
    display: flex;
    align-items: center;
    margin-top: 1rem;
    width: 100%;
}
#filters {
    display: flex;
    align-items: center;
    overflow-x: auto;
    white-space: nowrap;
    justify-content: space-between;
    scroll-behavior: smooth;
    flex-grow: 1; 
    max-width: 70%;
}

#filters::-webkit-scrollbar {
    display: none;
}
.right-menu {
    margin-left: auto; 
    display: flex;
    align-items: center;
    gap: 1rem; /* Space between Filter button and Tax Toggle */
    padding-left: 20px; /* Buffer so icons don't touch the buttons */
}

/* Clean up the fixed widths so they stay responsive */
.filter-panel, .tax-toggle {
    border: 1px solid #b0b0b0;
    border-radius: 12px;
    height: 3.2rem;
    display: flex;
    align-items: center;
    padding: 0 15px;
    font-size: 0.85rem;
    white-space: nowrap;
    width: auto;
}
.filter-panel {
    cursor: pointer;
    gap: 8px;
}

    
</style>

<div id="filters-container">
    <button id="prev-btn" onclick="scrollFilters('left')">
        <i class="fa-solid fa-chevron-left"></i>
    </button>

    <div id="filters">
        <div class="filter">
            <div class="icon"><i class="fa-solid fa-fire"></i></div>
            <div class="text">Trending</div>
        </div>
        <div class="filter">
            <div class="icon"><i class="fa-solid fa-house-chimney"></i></div>
            <div class="text">Tiny homes</div>
        </div>
        <div class="filter">
            <div class="icon"><i class="fa-solid fa-water"></i></div>
            <div class="text">Lakefront</div>
        </div>
        <div class="filter">
            <div class="icon"><i class="fa-solid fa-cable-car"></i></div>
            <div class="text">Cabins</div>
        </div>
        <div class="filter">
            <div class="icon"><i class="fa-solid fa-umbrella-beach"></i></div>
            <div class="text">Beach</div>
        </div>
        <div class="filter">
            <div class="icon"><i class="fa-solid fa-water-ladder"></i></div>
            <div class="text">Amazing Pools</div>
        </div>
        <div class="filter">
            <div class="icon"><i class="fa-brands fa-space-awesome"></i></div>
            <div class="text">OMG!</div>
        </div>
        <div class="filter">
            <div class="icon"><i class="fa-solid fa-sailboat"></i></div>
            <div class="text">Surfing</div>
        </div>
        <div class="filter">
            <div class="icon"><i class="fa-solid fa-city"></i></div>
            <div class="text">Iconic cities</div>
        </div>
        <div class="filter">
            <div class="icon"><i class="fa-solid fa-bed"></i></div>
            <div class="text">Rooms</div>
        </div>
        <div class="filter">
            <div class="icon"><i class="fa-solid fa-wheat-awn"></i></div>
            <div class="text">Farms</div>
        </div>
        <div class="filter">
            <div class="icon"><i class="fa-solid fa-campground"></i></div>
            <div class="text">Camping</div>
        </div>
    </div>
    <button id="next-btn" onclick="scrollFilters('right')">
        <i class="fa-solid fa-chevron-right"></i>
    </button>

    <div class="right-menu">
        <div class="filter-panel">
            <div class="icon"><i class="fa-solid fa-sliders"></i></div>
            <div>Filters</div>
        </div>

        <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>
        </div>
    </div>

    
</div>


<div class="row row-cols-sm-1 row-cols-md-3 mt-4 ">
    <% for(let listing of allListings){ %>
        <div class="col">
            <a href="/listings/<%= listing._id%>" class="listing-link">
            <div class="card col listing-card" style="width: 20rem;">
                <img 
                    src="<%= (listing.image && listing.image.url) ? listing.image.url : 'https://plus.unsplash.com/premium_photo-1711305682256-3b1874c923bd?w=1000&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxmZWF0dXJlZC1waG90b3MtZmVlZHw3Mnx8fGVufDB8fHx8fA%3D%3D' %>" 
                    class="card-img-top" 
                    alt="listing_image" 
                    style="height:20rem;"/>
                    <div class="card-img-overlay"></div>
                <div class="card-body">
                    <p class="card-text">
                        <%= listing.title %><br>
                        &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
                        <i class="tax-info"> &nbsp; &nbsp; +18% GST</i>
                    </p>
                </div>
            </div>
        </a>
        </div>
    <%}%>
</div>

<script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click",()=>{
        let taxInfo = document.getElementsByClassName("tax-info")
        for(let info of taxInfo){
            if(info.style.display !=inline){
                info.style.display = "inline";
            }else{
                info.style.display = "none";
            }
        }
    })
</script>